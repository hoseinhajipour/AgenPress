{
	"name": "agenpress/agenpress",
	"description": "AI Operating System for WordPress",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.1"
	},
	"suggest": {
		"woocommerce/action-scheduler": "Recommended for reliable async agent task execution.",
		"openai-php/client": "Optional OpenAI PHP SDK (plugin uses wp_remote_post by default)."
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"autoload": {
		"psr-4": {
			"AgenPress\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"AgenPress\\Tests\\": "tests/php/"
		}
	},
	"repositories": [
		{
			"type": "composer",
			"url": "https://repo.packagist.org"
		}
	],
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"php-http/discovery": true
		}
	}
}
