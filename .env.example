# AgenPress Environment Variables
# Copy to .env for local development reference.
# API keys are stored in WordPress options (encrypted), not here.

# WordPress debug (recommended for local dev)
WP_DEBUG=true
WP_DEBUG_LOG=true

# Optional: override default AI provider
# AGENPRESS_DEFAULT_PROVIDER=openai

# Optional: Redis queue driver (requires custom filter implementation)
# AGENPRESS_REDIS_HOST=127.0.0.1
# AGENPRESS_REDIS_PORT=6379
