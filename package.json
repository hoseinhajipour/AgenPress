{
	"name": "agenpress",
	"version": "0.1.0",
	"description": "AI Operating System for WordPress",
	"private": true,
	"scripts": {
		"build": "wp-scripts build",
		"postbuild": "php scripts/i18n.php all fa_IR",
		"start": "wp-scripts start",
		"lint:js": "wp-scripts lint-js",
		"format": "wp-scripts format",
		"i18n:pot": "php scripts/i18n.php pot",
		"i18n:po": "php scripts/i18n.php po fa_IR",
		"i18n:compile": "php scripts/i18n.php all fa_IR",
		"i18n": "npm run i18n:pot && npm run i18n:compile"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.0.0",
		"autoprefixer": "^10.4.0",
		"postcss": "^8.4.0",
		"tailwindcss": "^3.4.0"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.0.0",
		"@wordpress/components": "^28.0.0",
		"@wordpress/element": "^6.0.0",
		"@wordpress/i18n": "^5.0.0",
		"@wordpress/icons": "^10.0.0",
		"build": "^0.1.4"
	}
}
